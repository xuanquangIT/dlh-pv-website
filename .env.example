# =============================================================================
# PV Lakehouse — dlh-pv-website environment template
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL or local)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require
POSTGRES_SSLMODE=require
POSTGRES_CHANNEL_BINDING=require

# -----------------------------------------------------------------------------
# Databricks SQL Warehouse — main (analytics: Silver / Gold)
# -----------------------------------------------------------------------------
DATABRICKS_HOST=https://<workspace>.azuredatabricks.net/
DATABRICKS_TOKEN=dapi...
DATABRICKS_WAREHOUSE_ID=<warehouse-id>
DATABRICKS_SQL_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>

# -----------------------------------------------------------------------------
# Databricks SQL Warehouse — Solar Chat (isolated workload, Delta Sharing)
# Leave USE_SEPARATE_WAREHOUSE_FOR_SOLAR_CHAT=false to share the main warehouse.
# -----------------------------------------------------------------------------
USE_SEPARATE_WAREHOUSE_FOR_SOLAR_CHAT=true
SOLAR_CHAT_DATABRICKS_HOST=https://<solar-workspace>.azuredatabricks.net/
SOLAR_CHAT_DATABRICKS_TOKEN=dapi...
SOLAR_CHAT_DATABRICKS_WAREHOUSE_ID=<solar-warehouse-id>
SOLAR_CHAT_DATABRICKS_SQL_HTTP_PATH=/sql/1.0/warehouses/<solar-warehouse-id>

# -----------------------------------------------------------------------------
# Unity Catalog namespaces
# -----------------------------------------------------------------------------
UC_CATALOG=pv
UC_APP_CATALOG=dlh-web
UC_SILVER_SCHEMA=silver
UC_GOLD_SCHEMA=gold
UC_APP_SCHEMA=app

# =============================================================================
# Solar Chat — Model Picker (admin / ml_engineer only)
# =============================================================================
# A profile = ONE provider connection that exposes MANY selectable models.
# The UI dropdown groups models by profile; picking an entry sends both
# `model_profile_id` and `model_name` to the backend.
#
# To add a new provider: add another numbered block. No code edit needed.
#
#   SOLAR_CHAT_PROFILE_<N>_ID             required, unique string
#   SOLAR_CHAT_PROFILE_<N>_LABEL          shown as group header in picker
#   SOLAR_CHAT_PROFILE_<N>_PROVIDER       openai | anthropic | gemini
#   SOLAR_CHAT_PROFILE_<N>_BASE_URL       full URL of provider endpoint
#   SOLAR_CHAT_PROFILE_<N>_API_KEY        raw secret, OR:
#   SOLAR_CHAT_PROFILE_<N>_API_KEY_ENV    name of another env var with the key
#   SOLAR_CHAT_PROFILE_<N>_MODELS         CSV of model identifiers
#   SOLAR_CHAT_PROFILE_<N>_PRIMARY_MODEL  default model (must be in MODELS)
#   SOLAR_CHAT_PROFILE_<N>_FALLBACK_MODEL optional secondary model
#   SOLAR_CHAT_PROFILE_<N>_ALLOWED_ROLES  csv of {admin,ml_engineer} (default: both)
#   SOLAR_CHAT_PROFILE_<N>_DEFAULT        true = startup default profile
#   SOLAR_CHAT_PROFILE_<N>_DISABLED       true = hide without removing config

# Shared secrets — keep in their own vars and reference via _API_KEY_ENV.
# Rotate here without touching profile config.
COPILOT_LOCAL_API_KEY=<your-copilot-proxy-token>
GEMINI_API_KEY=<your-gemini-api-key>
OPENROUTER_API_KEY=<your-openrouter-api-key>

# Optional — OpenRouter leaderboard attribution (sent only on openrouter.ai requests)
SOLAR_CHAT_OPENROUTER_REFERER=http://localhost:8000
SOLAR_CHAT_OPENROUTER_APP_NAME=PV Lakehouse Solar Chat

# --- Profile 1: Local Copilot proxy (OpenAI-compatible) --------------------
SOLAR_CHAT_PROFILE_1_ID=copilot-local
SOLAR_CHAT_PROFILE_1_LABEL=Local Copilot proxy
SOLAR_CHAT_PROFILE_1_PROVIDER=openai
SOLAR_CHAT_PROFILE_1_BASE_URL=http://localhost:3456/v1
SOLAR_CHAT_PROFILE_1_API_KEY_ENV=COPILOT_LOCAL_API_KEY
SOLAR_CHAT_PROFILE_1_MODELS=gpt-4.1,gpt-4o,gpt-4o-mini
SOLAR_CHAT_PROFILE_1_PRIMARY_MODEL=gpt-4.1
SOLAR_CHAT_PROFILE_1_FALLBACK_MODEL=gpt-4o-mini
SOLAR_CHAT_PROFILE_1_DEFAULT=true

# --- Profile 2: Gemini direct API -----------------------------------------
SOLAR_CHAT_PROFILE_2_ID=gemini
SOLAR_CHAT_PROFILE_2_LABEL=Gemini (direct API)
SOLAR_CHAT_PROFILE_2_PROVIDER=gemini
SOLAR_CHAT_PROFILE_2_BASE_URL=https://generativelanguage.googleapis.com/v1beta
SOLAR_CHAT_PROFILE_2_API_KEY_ENV=GEMINI_API_KEY
SOLAR_CHAT_PROFILE_2_MODELS=gemini-3-flash-preview,gemini-3.1-flash-lite-preview,gemini-3.1-pro-preview
SOLAR_CHAT_PROFILE_2_PRIMARY_MODEL=gemini-3-flash-preview
SOLAR_CHAT_PROFILE_2_FALLBACK_MODEL=gemini-3.1-flash-lite-preview

# --- Profile 3: OpenRouter free-tier (OpenAI-compatible) ------------------
# Requires: openrouter.ai/settings/privacy → enable free providers
SOLAR_CHAT_PROFILE_3_ID=openrouter-free
SOLAR_CHAT_PROFILE_3_LABEL=OpenRouter (free)
SOLAR_CHAT_PROFILE_3_PROVIDER=openai
SOLAR_CHAT_PROFILE_3_BASE_URL=https://openrouter.ai/api/v1
SOLAR_CHAT_PROFILE_3_API_KEY_ENV=OPENROUTER_API_KEY
SOLAR_CHAT_PROFILE_3_MODELS=minimax/minimax-m2.5:free,openai/gpt-oss-120b:free,nvidia/nemotron-3-super-120b-a12b:free,google/gemma-4-31b-it:free
SOLAR_CHAT_PROFILE_3_PRIMARY_MODEL=minimax/minimax-m2.5:free
SOLAR_CHAT_PROFILE_3_FALLBACK_MODEL=openai/gpt-oss-120b:free
# SOLAR_CHAT_PROFILE_3_DISABLED=true   # uncomment to hide without deleting

# Add more profiles: Profile 4, 5, ...

# -----------------------------------------------------------------------------
# Solar Chat — legacy LLM config (used as server default when no profile active)
# -----------------------------------------------------------------------------
# SOLAR_CHAT_LLM_PROVIDER=openai
# SOLAR_CHAT_LLM_API_KEY=sk-...
# SOLAR_CHAT_LLM_BASE_URL=https://api.openai.com/v1
# SOLAR_CHAT_PRIMARY_MODEL=gpt-4o
# SOLAR_CHAT_FALLBACK_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Embeddings & RAG
# -----------------------------------------------------------------------------
SOLAR_CHAT_EMBEDDING_PRIMARY_API_KEY=<your-gemini-embedding-key>
SOLAR_CHAT_EMBEDDING_FALLBACK_API_KEY=<your-gemini-embedding-fallback-key>
SOLAR_CHAT_EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta
SOLAR_CHAT_EMBEDDING_MODEL=gemini-embedding-001
SOLAR_CHAT_EMBEDDING_DIMENSIONS=3072

SOLAR_CHAT_RAG_CHUNK_SIZE=512
SOLAR_CHAT_RAG_CHUNK_OVERLAP=64
SOLAR_CHAT_RAG_TOP_K=5
SOLAR_CHAT_DATA_ROOT=

# Enable search_documents tool (opt-in — only enable when docs are ingested)
# SOLAR_CHAT_RAG_ENABLED=1

# -----------------------------------------------------------------------------
# Engine version (Phase 1 prototype — v2 = primitives + semantic layer)
# v1 (default): 14 hardcoded tools, 16 prompt rules
# v2 (prototype): 6 primitives (discover_schema, execute_sql, ...) + YAML
# Use the eval CLI (scripts/solar_chat_eval_cli.py) to compare.
# -----------------------------------------------------------------------------
# SOLAR_CHAT_ENGINE=v2

# -----------------------------------------------------------------------------
# Chat history
# -----------------------------------------------------------------------------
SOLAR_CHAT_HISTORY_BACKEND=postgres

# -----------------------------------------------------------------------------
# Dev gating
# Unlocks: model picker for all roles, thinking-trace for analyst, ?debug=1
# -----------------------------------------------------------------------------
# APP_ENV=dev

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
AUTH_SECRET_KEY=<generate-with: openssl rand -base64 64>
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_COOKIE_NAME=pv_access_token
AUTH_COOKIE_SECURE=false   # set true in production (HTTPS only)

# -----------------------------------------------------------------------------
# Power BI Embedded (optional)
# -----------------------------------------------------------------------------
POWERBI_TENANT_ID=<tenant-id>
POWERBI_CLIENT_ID=<client-id>
POWERBI_CLIENT_SECRET=<client-secret>
POWERBI_WORKSPACE_ID=<workspace-id>
POWERBI_REPORT_ID=<report-id>
